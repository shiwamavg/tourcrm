{
  "name": "tour-crm-backend",
  "version": "1.0.0",
  "description": "Tour & Travel Agency CRM - Backend API (Quotation module)",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node src/scripts/migrate.js",
    "seed:admin": "node src/scripts/seed-admin.js",
    "test:integration": "mocha tests/integration/**/*.spec.js --timeout 20000",
    "test:integration-native": "node --test tests/integration/*.node.test.js",
    "test": "npm run test:integration-native"
    ,"backup":"node scripts/backup-runner.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "mysql2": "^3.11.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "mocha": "^10.2.0",
    "supertest": "^6.4.2",
    "chai": "^4.3.7"
  }
}
